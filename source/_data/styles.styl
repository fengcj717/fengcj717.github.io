:root
  --body-bg-color #f6f3ee
  --content-bg-color rgba(255, 255, 255, 0.9)
  --card-bg-color #fbfaf7
  --text-color #3f4650
  --blockquote-color #65707c
  --link-color #205d8f
  --link-hover-color #113b63
  --menu-item-bg-color rgba(32, 93, 143, 0.08)
  --theme-color #133a5a
  --btn-default-bg #fff
  --btn-default-color #205d8f
  --btn-default-border-color rgba(32, 93, 143, 0.25)
  --btn-default-hover-bg #205d8f
  --btn-default-hover-color #fff
  --btn-default-hover-border-color #205d8f
  --highlight-background #f5f7fa
  --highlight-foreground #38424e
  --highlight-gutter-background #e8edf2
  --highlight-gutter-foreground #51606d
  color-scheme light

body
  background:
    radial-gradient(circle at top left, rgba(32, 93, 143, 0.08), transparent 32%),
    radial-gradient(circle at top right, rgba(75, 120, 164, 0.06), transparent 26%),
    linear-gradient(180deg, #f8f5f0 0%, #f4f1eb 100%)
  color: var(--text-color)

.headband
  display: none

.site-brand-container,
.sidebar-inner,
.main-inner,
.footer-inner
  border-radius: 22px

.site-brand-container
  background: rgba(255, 255, 255, 0.9)
  border: 1px solid rgba(34, 54, 73, 0.08)
  box-shadow: 0 10px 30px rgba(18, 31, 46, 0.06)

.site-meta
  padding: 24px 0 18px

.site-title
  color: #17324a
  font-size: 1.6rem
  letter-spacing: 0.02em

.site-subtitle
  color: #667381
  font-size: 0.92rem

.site-nav
  background: rgba(255, 255, 255, 0.88)
  border-bottom: 1px solid rgba(34, 54, 73, 0.08)
  border-radius: 0 0 22px 22px
  border-top: 1px solid rgba(255, 255, 255, 0.3)
  backdrop-filter: blur(14px)

.site-nav-toggle .toggle,
.site-nav-right .toggle
  color: #17324a

.site-nav-toggle .toggle .toggle-line,
.site-nav-right .toggle .toggle-line
  background: #17324a

.menu .menu-item a
  border-radius: 14px

.menu .menu-item a:hover,
.menu .menu-item a.menu-item-active
  background: rgba(32, 93, 143, 0.09)
  color: var(--link-hover-color)

.main
  gap: 18px
  padding: 18px 0 0

.main-inner
  background: rgba(255, 255, 255, 0.82)
  border: 1px solid rgba(34, 54, 73, 0.08)
  box-shadow: 0 14px 40px rgba(17, 42, 71, 0.05)
  backdrop-filter: blur(18px)
  padding: 34px

.sidebar-inner
  background: rgba(255, 255, 255, 0.82)
  border: 1px solid rgba(34, 54, 73, 0.08)
  box-shadow: 0 14px 40px rgba(17, 42, 71, 0.05)
  backdrop-filter: blur(18px)

.sidebar .site-overview-wrap,
.sidebar .post-toc-wrap
  padding: 18px 10px 8px

.site-author-image
  border: 4px solid rgba(32, 93, 143, 0.12)
  box-shadow: 0 6px 20px rgba(17, 42, 71, 0.08)

.links-of-author-item a
  background: rgba(32, 93, 143, 0.05)
  border-radius: 12px

.site-state-item
  background: rgba(32, 93, 143, 0.04)
  border-radius: 14px

.posts-expand .post-header
  margin-bottom: 28px
  text-align: left

.posts-expand .post-title
  font-size: 1.92em
  font-weight: 600
  line-height: 1.25

.posts-expand .post-meta-container
  margin-top: 10px

.post-content
  color: var(--text-color)

.post-block
  margin-bottom: 22px

.post-block:first-of-type .post-content
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(249, 248, 244, 0.96))
  border: 1px solid rgba(32, 93, 143, 0.12)
  border-radius: 26px
  box-shadow: 0 18px 40px rgba(17, 42, 71, 0.06)
  overflow: hidden
  padding: 34px

.post-block:first-of-type .post-body
  font-size: 0.98rem
  line-height: 1.8

.home-landing
  display: grid
  gap: 20px

.hero-panel
  display: grid
  gap: 16px

.hero-kicker,
.section-kicker
  color: var(--link-color)
  font-size: 0.78rem
  font-weight: 700
  letter-spacing: 0.18em
  text-transform: uppercase

.hero-panel h1
  color: #13283f
  font-size: clamp(2.2rem, 4vw, 3.8rem)
  line-height: 1.08
  margin: 0
  max-width: 12ch

.hero-lead
  color: #4c5a67
  font-size: 1.05rem
  line-height: 1.9
  margin: 0
  max-width: 58ch

.hero-summary
  background: rgba(255, 255, 255, 0.72)
  border: 1px solid rgba(32, 93, 143, 0.12)
  border-radius: 22px
  max-width: 68ch
  padding: 18px 18px 16px

.hero-summary .btn
  display: inline-flex
  margin: 10px 10px 0 0

.hero-tags-inline
  display: flex
  flex-wrap: wrap
  gap: 8px
  margin-top: 12px

.hero-tags-inline span
  background: rgba(32, 93, 143, 0.08)
  border: 1px solid rgba(32, 93, 143, 0.12)
  border-radius: 999px
  color: #2f5e87
  display: inline-flex
  font-size: 0.84rem
  padding: 6px 10px

.hero-actions
  display: flex
  flex-wrap: wrap
  gap: 12px
  margin-top: 2px

.hero-actions .btn
  border-radius: 999px
  padding: 0 18px

.hero-actions .btn:first-child
  background: var(--btn-default-hover-bg)
  border-color: var(--btn-default-hover-bg)
  color: #fff

.hero-tags
  display: flex
  flex-wrap: wrap
  gap: 10px
  list-style: none
  margin: 6px 0 0
  padding: 0

.hero-tags li,
.service-tags li
  background: rgba(32, 93, 143, 0.08)
  border: 1px solid rgba(32, 93, 143, 0.12)
  border-radius: 999px
  color: #2f5e87
  font-size: 0.84rem
  padding: 7px 12px

.hero-grid,
.service-grid,
.case-grid
  display: grid
  gap: 14px

.hero-grid
  grid-template-columns: repeat(3, minmax(0, 1fr))

.service-grid,
.case-grid
  grid-template-columns: repeat(2, minmax(0, 1fr))

.info-card,
.service-card,
.case-card,
.contact-strip
  background: rgba(255, 255, 255, 0.78)
  border: 1px solid rgba(34, 54, 73, 0.08)
  border-radius: 22px
  box-shadow: 0 10px 24px rgba(17, 42, 71, 0.04)
  padding: 18px

.info-card h2,
.service-card h3,
.case-card h3,
.contact-strip h3
  color: #182b3e
  margin: 8px 0 10px

.info-card p,
.service-card p,
.case-card p,
.contact-strip p
  color: #54606d
  margin: 0

.service-tags
  display: flex
  flex-wrap: wrap
  gap: 8px
  list-style: none
  margin: 14px 0 0
  padding: 0

.section-title
  color: #182b3e
  font-size: 1.25rem
  margin: 0 0 12px

.contact-strip
  align-items: center
  display: flex
  flex-wrap: wrap
  gap: 16px
  justify-content: space-between

.contact-strip .btn
  border-radius: 999px

.contact-strip .btn:first-child
  background: var(--btn-default-hover-bg)
  border-color: var(--btn-default-hover-bg)
  color: #fff

.post-block:not(:first-of-type) .post-content
  background: rgba(255, 255, 255, 0.72)
  border: 1px solid rgba(34, 54, 73, 0.08)
  border-radius: 22px
  box-shadow: 0 10px 24px rgba(17, 42, 71, 0.04)
  padding: 28px 30px 22px

.post-block:not(:first-of-type) .post-body .post-button
  margin-top: 16px

.post-block:not(:first-of-type) .post-body p
  color: #4f5b68

.post-sticky-flag
  color: #205d8f

.post-eof
  background: linear-gradient(90deg, transparent, rgba(32, 93, 143, 0.2), transparent)
  width: 16%

.footer-inner
  color: #697481

@media (max-width: 991px)
  .main
    gap: 12px
    padding-top: 12px

  .main-inner
    padding: 22px

  .post-block:first-of-type .post-content
    padding: 22px

  .hero-grid,
  .service-grid,
  .case-grid
    grid-template-columns: 1fr

@media (max-width: 767px)
  .contact-strip
    align-items: flex-start
    flex-direction: column

  .hero-panel h1
    max-width: none
