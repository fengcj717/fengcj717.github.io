:root
  --body-bg-color #f6f8fb
  --content-bg-color rgba(255, 255, 255, 0.88)
  --card-bg-color #ffffff
  --text-color #253041
  --blockquote-color #65707c
  --link-color #2563eb
  --link-hover-color #1741a6
  --menu-item-bg-color rgba(37, 99, 235, 0.08)
  --theme-color #2563eb
  --btn-default-bg #fff
  --btn-default-color #243041
  --btn-default-border-color rgba(37, 99, 235, 0.18)
  --btn-default-hover-bg #2563eb
  --btn-default-hover-color #fff
  --btn-default-hover-border-color #2563eb
  --highlight-background #f4f7fb
  --highlight-foreground #364152
  --highlight-gutter-background #e4eaf2
  --highlight-gutter-foreground #566175
  color-scheme light

html
  scroll-behavior smooth

body
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 28%),
    radial-gradient(circle at top right, rgba(91, 143, 255, 0.08), transparent 22%),
    linear-gradient(180deg, #f8fafc 0%, #f3f6fa 100%)
  color: var(--text-color)

.headband
  display: none

header.header,
.sidebar-inner,
.main-inner,
.footer-inner,
.home-shell,
.home-hero,
.home-card,
.home-list,
.home-author
  border-radius: 24px

header.header
  margin-top: 14px
  overflow: hidden

.site-brand-container
  align-items: center
  background: rgba(255, 255, 255, 0.86)
  border: 1px solid rgba(37, 99, 235, 0.08)
  border-radius: 24px 24px 0 0
  box-shadow: 0 14px 32px rgba(15, 23, 42, 0.05)
  display: flex
  gap: 18px
  padding: 16px 22px

.site-meta
  padding: 0

.site-title
  color: #111827
  font-size: 1.4rem
  font-weight: 700
  letter-spacing: 0.01em

.site-subtitle
  color: #6b7280
  font-size: 0.88rem
  margin-top: 4px

.site-nav
  background: rgba(255, 255, 255, 0.9)
  border: 1px solid rgba(37, 99, 235, 0.08)
  border-top: 0
  backdrop-filter: blur(18px)

.site-nav-toggle .toggle,
.site-nav-right .toggle
  color: #0f172a

.site-nav-toggle .toggle .toggle-line,
.site-nav-right .toggle .toggle-line
  background: #0f172a

.menu .menu-item a
  border-radius: 14px

.menu .menu-item a:hover,
.menu .menu-item a.menu-item-active
  background: rgba(37, 99, 235, 0.08)
  color: var(--link-hover-color)

.main
  align-items: flex-start
  gap: 18px
  margin: 0 auto
  padding: 18px 0 0
  max-width: 1240px
  width: calc(100% - 24px)

.main-inner
  background: rgba(255, 255, 255, 0.86)
  border: 1px solid rgba(37, 99, 235, 0.08)
  box-shadow: 0 16px 44px rgba(15, 23, 42, 0.05)
  backdrop-filter: blur(20px)
  padding: 34px

.page-home .main-inner
  width: 100%

.page-home .post-block
  display: none

.page-home .main-inner
  display: none

.page-home .column
  width: 100%

.page-home .sidebar
  display: none

.page-home .home-shell
  display: grid
  gap: 24px

.page-home .main
  display: block
  max-width: 1240px
  width: calc(100% - 24px)

.home-shell
  background: transparent
  display: grid
  gap: 24px
  padding: 0

.home-hero
  align-items: center
  background: rgba(255, 255, 255, 0.78)
  border: 1px solid rgba(37, 99, 235, 0.08)
  box-shadow: 0 18px 48px rgba(15, 23, 42, 0.05)
  display: grid
  gap: 36px
  grid-template-columns: 1.12fr 0.88fr
  overflow: hidden
  padding: 54px 56px

.home-kicker
  color: var(--link-color)
  font-size: 0.8rem
  font-weight: 700
  letter-spacing: 0.18em
  margin-bottom: 12px
  text-transform: uppercase

.home-hero h1
  color: #0f172a
  font-size: clamp(2.4rem, 4.3vw, 4.2rem)
  font-weight: 800
  letter-spacing: -0.04em
  line-height: 1.08
  margin: 0
  max-width: 12ch

.home-hero p
  color: #4b5563
  font-size: 1.02rem
  line-height: 1.85
  margin: 18px 0 0
  max-width: 56ch

.home-actions
  display: flex
  flex-wrap: wrap
  gap: 12px
  margin-top: 26px

.home-actions .btn
  border-radius: 14px
  padding: 0 18px

.home-actions .btn:first-child
  background: linear-gradient(135deg, #2563eb, #3b82f6)
  border-color: transparent
  box-shadow: 0 14px 28px rgba(37, 99, 235, 0.22)
  color: #fff

.home-actions .btn:nth-child(2)
  background: rgba(255, 255, 255, 0.92)
  border-color: rgba(37, 99, 235, 0.14)

.home-hero-visual
  align-items: center
  display: flex
  justify-content: center
  min-height: 350px
  position: relative

.home-hero-visual::before
  background: radial-gradient(circle, rgba(37, 99, 235, 0.1), transparent 70%)
  content: ''
  inset: 10%
  position: absolute

.illustration
  aspect-ratio: 1.18
  max-height: 100%
  height: 360px
  position: relative
  max-width: 100%
  width: 440px

.cube,
.panel,
.tile
  position: absolute
  border-radius: 20px
  border: 1px solid rgba(148, 163, 184, 0.28)
  background: rgba(255, 255, 255, 0.7)
  backdrop-filter: blur(8px)
  box-shadow: 0 18px 40px rgba(37, 99, 235, 0.08)

.cube
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.92), rgba(37, 99, 235, 0.72))
  height: 148px
  left: 50%
  top: 38%
  transform: translate(-50%, -50%) rotate(-2deg)
  width: 148px

.cube::before
  border: 2px solid rgba(255, 255, 255, 0.36)
  border-radius: 18px
  content: ''
  inset: 18px
  position: absolute

.cube::after
  color: rgba(255, 255, 255, 0.96)
  content: 'LC'
  font-size: 2.2rem
  font-weight: 800
  left: 50%
  position: absolute
  top: 50%
  transform: translate(-50%, -50%)

.panel
  height: 104px
  width: 150px

.panel.left
  left: 10%
  top: 28%

.panel.right
  right: 8%
  top: 16%

.panel.bottom
  bottom: 10%
  left: 18%
  width: 170px

.tile
  height: 64px
  width: 92px

.tile.one
  left: 18%
  top: 16%

.tile.two
  right: 14%
  top: 56%

.tile.three
  bottom: 16%
  right: 20%

.node-line
  background: linear-gradient(90deg, rgba(59, 130, 246, 0.25), rgba(59, 130, 246, 0.02))
  border-radius: 999px
  height: 2px
  position: absolute

.node-line.a
  left: 24%
  top: 44%
  width: 18%
  transform: rotate(28deg)

.node-line.b
  right: 24%
  top: 44%
  width: 18%
  transform: rotate(-28deg)

.section-title
  color: #0f172a
  font-size: 1.08rem
  font-weight: 700
  margin: 0 0 14px

.section-head
  align-items: center
  display: flex
  justify-content: space-between
  margin-bottom: 12px

.section-head a
  color: #64748b
  font-size: 0.9rem

.project-grid,
.summary-grid
  display: grid
  gap: 16px

.project-grid
  grid-template-columns: repeat(3, minmax(0, 1fr))

.summary-grid
  grid-template-columns: 1.8fr 1fr

.home-card,
.home-list,
.home-author
  background: rgba(255, 255, 255, 0.8)
  border: 1px solid rgba(37, 99, 235, 0.08)
  box-shadow: 0 14px 34px rgba(15, 23, 42, 0.04)

.home-card
  padding: 20px
  position: relative

.home-card .badge
  align-items: center
  background: rgba(37, 99, 235, 0.08)
  border-radius: 999px
  color: var(--link-color)
  display: inline-flex
  font-size: 0.75rem
  font-weight: 700
  padding: 5px 10px

.home-card h3
  color: #111827
  font-size: 1.05rem
  margin: 14px 0 8px

.home-card p
  color: #5b6473
  font-size: 0.92rem
  line-height: 1.75
  margin: 0

.tag-row
  display: flex
  flex-wrap: wrap
  gap: 8px
  margin-top: 14px

.tag-row span
  background: #f4f7fb
  border-radius: 999px
  color: #64748b
  font-size: 0.78rem
  padding: 5px 10px

.home-lower
  display: grid
  gap: 16px
  grid-template-columns: 1.6fr 1fr

.home-list
  padding: 18px

.home-list-item
  align-items: center
  border-top: 1px solid rgba(148, 163, 184, 0.16)
  display: grid
  gap: 12px
  grid-template-columns: 104px 1fr auto
  padding: 16px 0

.home-list-item:first-of-type
  border-top: 0
  padding-top: 2px

.home-list-thumb
  border-radius: 12px
  height: 64px
  object-fit: cover
  width: 104px

.home-list-meta h4
  color: #0f172a
  font-size: 1rem
  line-height: 1.35
  margin: 0 0 8px

.home-list-meta p
  color: #667085
  font-size: 0.9rem
  line-height: 1.7
  margin: 0

.home-list-info
  color: #94a3b8
  font-size: 0.8rem
  white-space: nowrap

.home-author
  display: grid
  gap: 16px
  padding: 18px

.author-head
  display: flex
  gap: 14px
  align-items: center

.author-head img
  border-radius: 999px
  height: 76px
  width: 76px

.author-name
  color: #0f172a
  font-size: 1.1rem
  font-weight: 700
  margin: 0

.author-role
  background: rgba(37, 99, 235, 0.09)
  border-radius: 999px
  color: #2563eb
  display: inline-flex
  font-size: 0.8rem
  margin-top: 8px
  padding: 4px 10px

.author-text
  color: #5b6473
  font-size: 0.92rem
  line-height: 1.85
  margin: 0

.author-stats
  display: grid
  gap: 10px
  grid-template-columns: repeat(4, 1fr)

.author-stat
  background: #f7f9fc
  border-radius: 16px
  padding: 12px
  text-align: center

.author-stat strong
  color: #111827
  display: block
  font-size: 1.15rem

.author-stat span
  color: #64748b
  font-size: 0.76rem

.author-links
  display: flex
  gap: 10px
  justify-content: flex-start

.author-links a
  align-items: center
  background: #f7f9fc
  border-radius: 999px
  color: #111827
  display: inline-flex
  height: 38px
  justify-content: center
  width: 38px

.author-cta
  display: flex
  justify-content: stretch

.author-cta .btn
  background: linear-gradient(135deg, #2563eb, #3b82f6)
  border-color: transparent
  color: #fff
  width: 100%

.footer-inner
  color: #6b7280
  padding-top: 14px

.page-home .footer-inner
  margin-top: 4px

.post-block:first-of-type
  padding-top: 40px

.posts-expand .post-header
  text-align: left

.posts-expand .post-title
  font-size: 1.6em
  font-weight: 600

.posts-expand .post-title-link
  color: #0f172a

.posts-expand .post-body
  color: #4b5563

@media (max-width: 1100px)
  .home-hero,
  .summary-grid,
  .home-lower
    grid-template-columns: 1fr

  .project-grid
    grid-template-columns: repeat(2, minmax(0, 1fr))

@media (max-width: 767px)
  .main
    width: calc(100% - 16px)

  .main-inner
    padding: 22px

  .site-brand-container
    border-radius: 20px 20px 0 0
    padding: 14px 16px

  .home-hero
    padding: 24px

  .home-hero h1
    max-width: none

  .project-grid,
  .author-stats
    grid-template-columns: 1fr

  .home-list-item
    grid-template-columns: 1fr

  .home-list-info
    white-space: normal
