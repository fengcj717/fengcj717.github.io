:root
  --body-bg-color #f5f6fa
  --content-bg-color #ffffff
  --card-bg-color #ffffff
  --text-color #273142
  --blockquote-color #667085
  --link-color #345cf6
  --link-hover-color #2447cf
  --menu-item-bg-color #edf1ff
  --theme-color #345cf6
  --btn-default-bg #ffffff
  --btn-default-color #273142
  --btn-default-border-color #e3e7ef
  --btn-default-hover-bg #345cf6
  --btn-default-hover-color #ffffff
  --btn-default-hover-border-color #345cf6
  --highlight-background #f5f7fb
  --highlight-foreground #344054
  --highlight-gutter-background #eef1f6
  --highlight-gutter-foreground #667085
  --home-border #e6e9f0
  --home-muted #697386
  --home-shadow 0 10px 32px rgba(38, 49, 80, 0.06)
  color-scheme light

html
  scroll-behavior smooth

body
  background: #f5f6fa
  color: var(--text-color)
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif

.headband
  display: none

header.header
  background: rgba(255, 255, 255, 0.94)
  border-bottom: 1px solid rgba(224, 228, 237, 0.86)
  box-shadow: 0 4px 18px rgba(36, 46, 74, 0.035)
  margin: 0
  position: relative
  z-index: 20

.header-inner
  max-width: 1240px
  padding: 0 16px
  width: calc(100% - 24px)

.site-brand-container
  align-items: center
  background: transparent
  border: 0
  box-shadow: none
  display: flex
  gap: 12px
  min-height: 70px
  padding: 10px 0

.site-meta
  padding: 0

.site-title
  color: #171d2b
  font-size: 1.18rem
  font-weight: 760
  letter-spacing: -0.02em

.site-subtitle
  color: #7b8494
  font-size: 0.74rem
  margin-top: 3px

.site-nav
  background: transparent
  border: 0
  backdrop-filter: none

.menu .menu-item a
  border-radius: 10px
  color: #353d4d
  font-size: 0.92rem
  font-weight: 600
  padding: 8px 13px

.menu .menu-item a:hover,
.menu .menu-item a.menu-item-active
  background: #edf1ff
  color: #345cf6

.site-nav-toggle .toggle,
.site-nav-right .toggle
  color: #222a38

.site-nav-toggle .toggle .toggle-line,
.site-nav-right .toggle .toggle-line
  background: #222a38

.main
  align-items: flex-start
  gap: 18px
  margin: 0 auto
  max-width: 1240px
  padding: 18px 0 0
  width: calc(100% - 24px)

.main-inner
  background: #ffffff
  border: 1px solid var(--home-border)
  border-radius: 18px
  box-shadow: var(--home-shadow)
  padding: 34px

.page-home .main
  display: block
  max-width: 1240px
  padding-top: 12px
  width: calc(100% - 24px)

.page-home header.header
  background: transparent
  border: 0
  box-shadow: none
  display: grid
  grid-template-columns: auto 1fr
  width: 100%

.page-home .site-brand-container
  background: #ffffff
  border: 1px solid var(--home-border)
  border-radius: 16px 0 0 16px
  border-right: 0
  min-height: 66px
  padding: 9px 18px

.page-home .site-nav
  align-items: center
  background: #ffffff
  border: 1px solid var(--home-border)
  border-left: 0
  border-radius: 0 16px 16px 0
  display: flex
  justify-content: flex-end
  min-height: 66px

.page-home .site-nav .menu
  align-items: center
  display: flex
  flex-wrap: nowrap
  justify-content: flex-end
  margin: 0
  padding: 0 12px
  width: 100%

.page-home .site-nav .menu-item
  margin: 0

.page-home .home-shell
  grid-column: 1 / -1
  margin-top: 12px

.page-home .main-inner,
.page-home .post-block,
.page-home .sidebar
  display: none

.page-home .sidebar-toggle
  display: none

.page-home .column
  width: 100%

.home-shell
  display: grid
  gap: 16px
  width: 100%

.home-notice
  align-items: center
  background: #ffffff
  border: 1px solid var(--home-border)
  border-radius: 14px
  color: #505a6d
  display: grid
  font-size: 0.88rem
  gap: 12px
  grid-template-columns: auto 1fr auto
  min-height: 48px
  padding: 8px 14px
  transition: border-color .2s ease, transform .2s ease

.home-notice:hover
  border-color: #cdd6ff
  color: #345cf6
  transform: translateY(-1px)

.home-notice-label
  background: #345cf6
  border-radius: 8px
  color: #ffffff
  font-size: 0.76rem
  font-weight: 700
  padding: 6px 9px

.home-hero
  background: #ffffff
  border: 1px solid var(--home-border)
  border-radius: 20px
  box-shadow: var(--home-shadow)
  display: grid
  grid-template-columns: .9fr 1.1fr
  min-height: 390px
  overflow: hidden

.home-copy
  align-content: center
  display: grid
  padding: 48px 26px 48px 48px

.home-kicker
  color: #345cf6
  font-size: 0.72rem
  font-weight: 800
  letter-spacing: .14em
  margin-bottom: 13px

.home-hero h1
  color: #171d2b
  font-size: clamp(2.35rem, 4vw, 3.65rem)
  font-weight: 800
  letter-spacing: -0.055em
  line-height: 1.12
  margin: 0

.home-hero p
  color: #626d80
  font-size: 1rem
  line-height: 1.82
  margin: 18px 0 0
  max-width: 570px

.home-actions
  display: flex
  flex-wrap: wrap
  gap: 10px
  margin-top: 24px

.home-actions .btn
  align-items: center
  border-radius: 11px
  display: inline-flex
  font-size: .9rem
  font-weight: 700
  gap: 8px
  height: 42px
  padding: 0 17px

.home-primary
  background: #345cf6
  border-color: #345cf6
  box-shadow: 0 8px 18px rgba(52, 92, 246, .2)
  color: #ffffff

.home-primary:hover
  background: #2447cf
  border-color: #2447cf
  color: #ffffff

.home-secondary
  background: #ffffff
  border-color: #dfe3eb
  color: #3b4557

.home-proof
  display: flex
  flex-wrap: wrap
  gap: 15px
  margin-top: 21px

.home-proof span
  color: #778195
  font-size: .78rem

.home-proof i
  color: #32b48a
  margin-right: 3px

.home-hero-visual
  background: #eef3ff
  min-height: 390px
  overflow: hidden
  position: relative

.home-hero-visual img
  height: 100%
  left: 0
  object-fit: cover
  object-position: center
  position: absolute
  top: 0
  transition: transform .55s ease
  width: 100%

.home-hero:hover .home-hero-visual img
  transform: scale(1.025)

.visual-caption
  background: rgba(255, 255, 255, .9)
  border: 1px solid rgba(255, 255, 255, .8)
  border-radius: 13px
  bottom: 18px
  box-shadow: 0 10px 28px rgba(25, 47, 95, .12)
  display: grid
  left: 18px
  padding: 11px 14px
  position: absolute

.visual-caption span
  color: #748095
  font-size: .7rem

.visual-caption strong
  color: #20283a
  font-size: .9rem
  margin-top: 3px

.home-tabs
  align-items: center
  background: #ffffff
  border: 1px solid var(--home-border)
  border-radius: 14px
  display: flex
  gap: 2px
  min-height: 54px
  overflow-x: auto
  padding: 7px 9px

.home-tabs a
  border-radius: 9px
  color: #4f596a
  flex: 0 0 auto
  font-size: .86rem
  font-weight: 650
  padding: 8px 12px

.home-tabs a:hover,
.home-tabs a.active
  background: #345cf6
  color: #ffffff

.home-tabs .home-tabs-more
  color: #697386
  margin-left: auto

.home-tabs .home-tabs-more:hover
  background: #edf1ff
  color: #345cf6

.home-section
  background: #ffffff
  border: 1px solid var(--home-border)
  border-radius: 18px
  box-shadow: var(--home-shadow)
  padding: 22px

.section-head
  align-items: flex-end
  display: flex
  justify-content: space-between
  margin-bottom: 16px

.section-head.compact
  align-items: center
  margin-bottom: 6px

.section-title
  color: #20283a
  font-size: 1.18rem
  font-weight: 760
  letter-spacing: -.02em
  margin: 2px 0 0

.section-eyebrow
  color: #8b95a6
  display: block
  font-size: .64rem
  font-weight: 800
  letter-spacing: .14em

.section-head a
  color: #7b8494
  font-size: .8rem

.section-head a:hover
  color: #345cf6

.project-grid
  display: grid
  gap: 12px
  grid-template-columns: repeat(3, minmax(0, 1fr))

.home-card
  border: 1px solid transparent
  border-radius: 16px
  color: inherit
  display: block
  min-height: 238px
  overflow: hidden
  padding: 20px
  position: relative
  transition: box-shadow .22s ease, transform .22s ease

.home-card:hover
  box-shadow: 0 12px 28px rgba(41, 55, 88, .1)
  color: inherit
  transform: translateY(-3px)

.card-blue
  background: #eef3ff
  border-color: #dce6ff

.card-violet
  background: #f3efff
  border-color: #e8defe

.card-cyan
  background: #ebf9f7
  border-color: #d8f0eb

.home-card-top
  align-items: center
  display: flex
  justify-content: space-between

.project-icon
  align-items: center
  background: #ffffff
  border-radius: 12px
  box-shadow: 0 7px 18px rgba(34, 49, 84, .08)
  display: inline-flex
  font-size: 1.1rem
  height: 42px
  justify-content: center
  width: 42px

.card-blue .project-icon
  color: #345cf6

.card-violet .project-icon
  color: #8256dc

.card-cyan .project-icon
  color: #1f9f83

.home-card .badge
  background: rgba(255, 255, 255, .78)
  border: 1px solid rgba(255, 255, 255, .9)
  border-radius: 8px
  color: #667085
  font-size: .68rem
  font-weight: 700
  padding: 5px 8px

.home-card h3
  color: #20283a
  font-size: 1.05rem
  margin: 22px 0 9px

.home-card p
  color: #687386
  font-size: .84rem
  line-height: 1.72
  margin: 0

.tag-row
  display: flex
  flex-wrap: wrap
  gap: 6px
  margin-top: 16px

.tag-row span
  background: rgba(255, 255, 255, .68)
  border-radius: 7px
  color: #6a7486
  font-size: .7rem
  padding: 4px 7px

.summary-grid
  display: grid
  gap: 14px
  grid-template-columns: 1.75fr .85fr

.home-list,
.home-author
  background: #ffffff
  border: 1px solid var(--home-border)
  border-radius: 18px
  box-shadow: var(--home-shadow)

.home-list
  padding: 20px 22px 8px

.home-list-item
  align-items: center
  border-top: 1px solid #edf0f5
  color: inherit
  display: grid
  gap: 14px
  grid-template-columns: 76px 1fr auto
  padding: 15px 0

.home-list-item:hover
  color: inherit

.home-list-item:hover h4
  color: #345cf6

.home-list-thumb
  align-items: center
  border-radius: 13px
  display: inline-flex
  font-size: 1.25rem
  height: 58px
  justify-content: center
  width: 76px

.thumb-blue
  background: #e9efff
  color: #345cf6

.thumb-violet
  background: #f1ebff
  color: #8256dc

.thumb-cyan
  background: #e5f7f3
  color: #1f9f83

.article-category
  color: #8a94a5
  display: block
  font-size: .68rem
  margin-bottom: 4px

.home-list-meta h4
  color: #20283a
  font-size: .94rem
  line-height: 1.35
  margin: 0 0 5px
  transition: color .2s ease

.home-list-meta p
  color: #778195
  font-size: .78rem
  line-height: 1.55
  margin: 0

.home-list-info
  color: #9aa3b2
  font-size: .7rem
  white-space: nowrap

.home-author
  background: #3158e8
  color: #ffffff
  display: grid
  gap: 16px
  overflow: hidden
  padding: 22px

.author-welcome
  background: rgba(255, 255, 255, .14)
  border-radius: 999px
  color: rgba(255, 255, 255, .88)
  font-size: .69rem
  justify-self: start
  padding: 5px 9px

.author-head
  align-items: center
  display: flex
  gap: 12px

.author-head img
  background: #ffffff
  border: 3px solid rgba(255, 255, 255, .7)
  border-radius: 50%
  height: 64px
  object-fit: cover
  width: 64px

.author-name
  color: #ffffff
  font-size: 1.06rem
  font-weight: 750
  margin: 0

.author-role
  color: rgba(255, 255, 255, .78)
  display: inline-block
  font-size: .72rem
  margin-top: 4px

.author-text
  color: rgba(255, 255, 255, .82)
  font-size: .8rem
  line-height: 1.7
  margin: 0

.author-stats
  display: grid
  gap: 8px
  grid-template-columns: repeat(3, 1fr)

.author-stat
  background: rgba(255, 255, 255, .1)
  border: 1px solid rgba(255, 255, 255, .1)
  border-radius: 11px
  padding: 10px 6px
  text-align: center

.author-stat strong
  color: #ffffff
  display: block
  font-size: .94rem

.author-stat span
  color: rgba(255, 255, 255, .7)
  font-size: .61rem

.author-links
  display: flex
  gap: 8px

.author-links a
  align-items: center
  background: rgba(255, 255, 255, .12)
  border: 1px solid rgba(255, 255, 255, .12)
  border-radius: 10px
  color: #ffffff
  display: inline-flex
  height: 36px
  justify-content: center
  width: 36px

.author-links a:hover
  background: #ffffff
  color: #3158e8

.author-cta
  align-items: center
  background: #ffffff
  border-radius: 10px
  color: #3158e8
  display: flex
  font-size: .78rem
  font-weight: 750
  justify-content: space-between
  padding: 11px 13px

.author-cta:hover
  color: #2447cf

.footer-inner
  color: #7e8797
  padding-top: 20px

.page-home .footer-inner
  margin-top: 4px

.post-block:first-of-type
  padding-top: 40px

.posts-expand .post-header
  text-align: left

.posts-expand .post-title
  font-size: 1.6em
  font-weight: 650

.posts-expand .post-title-link
  color: #1f2735

.posts-expand .post-body
  color: #4f596b

@media (max-width: 1100px)
  .home-hero
    grid-template-columns: 1fr 1fr

  .home-copy
    padding: 38px 24px 38px 34px

  .summary-grid
    grid-template-columns: 1.45fr .75fr

@media (max-width: 900px)
  .home-hero,
  .summary-grid
    grid-template-columns: 1fr

  .home-hero-visual
    min-height: 330px

  .project-grid
    grid-template-columns: 1fr

  .home-card
    min-height: auto

@media (max-width: 767px)
  .header-inner,
  .main,
  .page-home .main
    width: calc(100% - 16px)

  .site-brand-container
    min-height: 58px

  .page-home header.header
    display: block

  .page-home .site-brand-container
    border-radius: 14px
    border-right: 1px solid var(--home-border)

  .page-home .site-nav
    border: 0
    border-radius: 14px
    display: block
    height: 0
    margin: 0
    min-height: 0
    overflow: hidden
    visibility: hidden

  .page-home .site-nav .menu
    display: block
    padding: 8px

  body.site-nav-on .page-home .site-nav
    border: 1px solid var(--home-border)
    height: var(--scroll-height)
    margin-top: 8px
    visibility: unset

  .main-inner
    padding: 22px

  .home-notice
    grid-template-columns: auto 1fr

  .home-notice > i
    display: none

  .home-copy
    padding: 30px 22px

  .home-hero h1
    font-size: 2.35rem

  .home-hero p
    font-size: .9rem

  .home-hero-visual
    min-height: 260px

  .visual-caption
    bottom: 12px
    left: 12px

  .home-tabs .home-tabs-more
    margin-left: 0

  .home-section,
  .home-list,
  .home-author
    padding: 18px

  .home-list-item
    align-items: start
    grid-template-columns: 58px 1fr

  .home-list-thumb
    height: 50px
    width: 58px

  .home-list-info
    display: none

  .home-list-meta p
    display: none

  .author-stats
    grid-template-columns: repeat(3, 1fr)

// Unified landing pages: services and cases
.page-landing .main
  display: block
  max-width: 1240px
  padding-top: 12px
  width: calc(100% - 24px)

.page-landing .column
  width: 100%

.page-landing header.header
  background: transparent
  border: 0
  box-shadow: none
  display: grid
  grid-template-columns: auto 1fr
  width: 100%

.page-landing .site-brand-container
  background: #ffffff
  border: 1px solid var(--home-border)
  border-radius: 16px 0 0 16px
  border-right: 0
  min-height: 66px
  padding: 9px 18px

.page-landing .site-nav
  align-items: center
  background: #ffffff
  border: 1px solid var(--home-border)
  border-left: 0
  border-radius: 0 16px 16px 0
  display: flex
  justify-content: flex-end
  min-height: 66px

.page-landing .site-nav .menu
  align-items: center
  display: flex
  flex-wrap: nowrap
  justify-content: flex-end
  margin: 0
  padding: 0 12px
  width: 100%

.page-landing .site-nav .menu-item
  margin: 0

.page-landing .sidebar,
.page-landing .sidebar-toggle
  display: none

.page-landing .main-inner
  background: transparent
  border: 0
  box-shadow: none
  margin-top: 12px
  padding: 0
  width: 100%

.page-landing .post-block,
.page-landing .post-block:first-of-type
  margin: 0
  padding: 0

.page-landing .post-header,
.page-landing .post-footer
  display: none

.page-landing .post-body
  color: #4f596b
  font-size: 1em

.landing-page
  display: grid
  gap: 16px

.landing-hero
  background: #ffffff
  border: 1px solid var(--home-border)
  border-radius: 20px
  box-shadow: var(--home-shadow)
  display: grid
  grid-template-columns: 1.25fr .75fr
  min-height: 390px
  overflow: hidden

.landing-hero-copy
  align-content: center
  display: grid
  padding: 48px

.landing-kicker,
.landing-eyebrow
  color: #345cf6
  font-size: .68rem
  font-weight: 800
  letter-spacing: .14em

.landing-hero h1
  color: #171d2b
  font-size: clamp(2.35rem, 4vw, 3.7rem)
  font-weight: 800
  letter-spacing: -.055em
  line-height: 1.12
  margin: 13px 0 0

.landing-hero-copy > p
  color: #626d80
  font-size: .98rem
  line-height: 1.85
  margin: 18px 0 0
  max-width: 630px

.landing-actions
  display: flex
  flex-wrap: wrap
  gap: 10px
  margin-top: 24px

.landing-btn
  align-items: center
  border: 1px solid transparent
  border-radius: 11px
  display: inline-flex
  font-size: .86rem
  font-weight: 750
  gap: 8px
  justify-content: center
  min-height: 42px
  padding: 0 17px

.landing-btn.primary
  background: #345cf6
  box-shadow: 0 8px 18px rgba(52, 92, 246, .2)
  color: #ffffff

.landing-btn.primary:hover
  background: #2447cf
  color: #ffffff

.landing-btn.secondary
  background: #ffffff
  border-color: #dfe3eb
  color: #3b4557

.landing-btn.secondary:hover
  border-color: #cbd5ff
  color: #345cf6

.landing-hero-panel
  align-content: center
  background: #3158e8
  color: #ffffff
  display: grid
  padding: 42px

.landing-panel-label
  background: rgba(255, 255, 255, .13)
  border-radius: 999px
  font-size: .7rem
  justify-self: start
  padding: 5px 9px

.landing-hero-panel > strong
  color: #ffffff
  font-size: 1.55rem
  line-height: 1.35
  margin-top: 20px

.landing-hero-panel > p
  color: rgba(255, 255, 255, .8)
  font-size: .86rem
  line-height: 1.7
  margin: 12px 0 0

.landing-panel-points
  display: grid
  gap: 9px
  margin-top: 24px

.landing-panel-points span
  color: rgba(255, 255, 255, .88)
  font-size: .8rem

.landing-panel-points i
  margin-right: 6px

.landing-section
  background: #ffffff
  border: 1px solid var(--home-border)
  border-radius: 18px
  box-shadow: var(--home-shadow)
  padding: 24px

.landing-section-head
  align-items: flex-end
  display: flex
  gap: 30px
  justify-content: space-between
  margin-bottom: 18px

.landing-section-head h2,
.landing-cta h2
  color: #20283a
  font-size: 1.35rem
  letter-spacing: -.025em
  margin: 4px 0 0

.landing-section-head > p
  color: #8790a0
  font-size: .76rem
  margin: 0
  max-width: 420px
  text-align: right

.service-card-grid
  display: grid
  gap: 12px
  grid-template-columns: repeat(3, 1fr)

.service-card
  border: 1px solid transparent
  border-radius: 16px
  display: flex
  flex-direction: column
  min-height: 360px
  padding: 20px

.service-blue
  background: #eef3ff
  border-color: #dce6ff

.service-violet
  background: #f3efff
  border-color: #e8defe

.service-cyan
  background: #ebf9f7
  border-color: #d8f0eb

.service-card-head
  align-items: center
  display: flex
  justify-content: space-between

.landing-icon
  align-items: center
  background: #ffffff
  border-radius: 12px
  box-shadow: 0 7px 18px rgba(34, 49, 84, .08)
  color: #345cf6
  display: inline-flex
  font-size: 1.05rem
  height: 42px
  justify-content: center
  width: 42px

.service-violet .landing-icon,
.cover-violet .landing-icon
  color: #8256dc

.service-cyan .landing-icon,
.cover-cyan .landing-icon
  color: #1f9f83

.landing-icon.large
  font-size: 1.2rem
  height: 48px
  width: 48px

.landing-badge
  background: rgba(255, 255, 255, .76)
  border-radius: 8px
  color: #697386
  font-size: .67rem
  font-weight: 700
  padding: 5px 8px

.service-card h3
  color: #20283a
  font-size: 1.1rem
  margin: 22px 0 8px

.service-card > p
  color: #697386
  font-size: .8rem
  line-height: 1.7
  margin: 0

.service-card ul
  color: #4f596b
  font-size: .78rem
  line-height: 1.8
  margin: 16px 0
  padding-left: 20px

.service-card li
  margin: 2px 0

.service-deliverable
  background: rgba(255, 255, 255, .7)
  border-radius: 9px
  color: #5f697b
  font-size: .7rem
  margin-top: auto
  padding: 9px 10px

.process-grid
  display: grid
  gap: 10px
  grid-template-columns: repeat(4, 1fr)

.process-item
  border-left: 2px solid #dfe5f4
  padding: 8px 14px

.process-item > span
  color: #345cf6
  display: block
  font-size: .66rem
  font-weight: 800

.process-item strong
  color: #273142
  display: block
  font-size: .9rem
  margin-top: 6px

.process-item p
  color: #7a8495
  font-size: .72rem
  line-height: 1.55
  margin: 6px 0 0

.landing-cta
  align-items: center
  background: #3158e8
  border-radius: 18px
  box-shadow: 0 12px 30px rgba(49, 88, 232, .18)
  color: #ffffff
  display: flex
  justify-content: space-between
  padding: 28px 32px

.landing-cta .landing-eyebrow
  color: rgba(255, 255, 255, .65)

.landing-cta h2
  color: #ffffff

.landing-cta p
  color: rgba(255, 255, 255, .76)
  font-size: .78rem
  margin: 8px 0 0

.landing-btn.light
  background: #ffffff
  color: #3158e8
  flex: 0 0 auto

.landing-btn.light:hover
  color: #2447cf

.case-principle
  background: #202c4f

.principle-list
  display: grid
  gap: 16px
  margin-top: 22px

.principle-list > div
  align-items: start
  border-top: 1px solid rgba(255, 255, 255, .12)
  display: grid
  gap: 12px
  grid-template-columns: 28px 1fr
  padding-top: 14px

.principle-list > div:first-child
  border-top: 0
  padding-top: 0

.principle-list span
  color: #91a8ff
  font-size: .68rem
  font-weight: 800

.principle-list p
  color: rgba(255, 255, 255, .72)
  font-size: .75rem
  line-height: 1.6
  margin: 0

.principle-list strong
  color: #ffffff
  display: block
  font-size: .84rem
  margin-bottom: 2px

.case-grid
  display: grid
  gap: 12px
  grid-template-columns: repeat(3, 1fr)

.case-card
  border: 1px solid #e5e8ef
  border-radius: 16px
  overflow: hidden
  transition: box-shadow .22s ease, transform .22s ease

.case-card:hover
  box-shadow: 0 12px 28px rgba(41, 55, 88, .09)
  transform: translateY(-3px)

.case-card-cover
  align-items: center
  display: flex
  gap: 14px
  min-height: 112px
  padding: 18px

.cover-blue
  background: #eef3ff

.cover-violet
  background: #f3efff

.cover-cyan
  background: #ebf9f7

.case-card-cover > div
  display: grid

.case-card-cover div > span
  color: #8b95a6
  font-size: .62rem
  font-weight: 800
  letter-spacing: .12em

.case-card-cover strong
  color: #20283a
  font-size: .98rem
  margin-top: 4px

.case-card-body
  padding: 18px

.case-detail
  margin-bottom: 14px

.case-detail > span
  color: #345cf6
  display: block
  font-size: .67rem
  font-weight: 750
  margin-bottom: 4px

.case-detail p
  color: #667085
  font-size: .76rem
  line-height: 1.65
  margin: 0

.case-result
  align-items: flex-start
  background: #f5f7fb
  border-radius: 9px
  color: #667085
  display: flex
  font-size: .68rem
  gap: 7px
  line-height: 1.55
  padding: 9px

.case-result i
  color: #345cf6
  margin-top: 2px

.case-tags
  display: flex
  flex-wrap: wrap
  gap: 5px
  margin-top: 13px

.case-tags span
  border: 1px solid #e4e8ef
  border-radius: 7px
  color: #778195
  font-size: .63rem
  padding: 3px 6px

.method-layout
  display: grid
  gap: 20px
  grid-template-columns: .72fr 1.28fr

.method-intro
  background: #eef3ff
  border-radius: 14px
  padding: 20px

.method-intro h3
  color: #20283a
  font-size: 1rem
  margin: 18px 0 8px

.method-intro p
  color: #697386
  font-size: .76rem
  line-height: 1.65
  margin: 0

.method-steps
  display: grid
  gap: 8px
  grid-template-columns: repeat(2, 1fr)

.method-steps > div
  align-items: start
  border: 1px solid #e6e9f0
  border-radius: 12px
  display: grid
  gap: 10px
  grid-template-columns: 28px 1fr
  padding: 14px

.method-steps span
  align-items: center
  background: #345cf6
  border-radius: 8px
  color: #ffffff
  display: inline-flex
  font-size: .68rem
  height: 28px
  justify-content: center
  width: 28px

.method-steps p
  color: #768092
  font-size: .71rem
  line-height: 1.55
  margin: 0

.method-steps strong
  color: #273142
  display: block
  font-size: .8rem
  margin-bottom: 2px

@media (max-width: 900px)
  .landing-hero,
  .method-layout
    grid-template-columns: 1fr

  .landing-hero-panel
    min-height: 300px

  .service-card-grid,
  .case-grid
    grid-template-columns: 1fr

  .service-card
    min-height: auto

  .process-grid
    grid-template-columns: repeat(2, 1fr)

@media (max-width: 767px)
  .page-landing .main
    width: calc(100% - 16px)

  .page-landing header.header
    display: block

  .page-landing .site-brand-container
    border-radius: 14px
    border-right: 1px solid var(--home-border)

  .page-landing .site-nav
    border: 0
    border-radius: 14px
    display: block
    height: 0
    margin: 0
    min-height: 0
    overflow: hidden
    visibility: hidden

  .page-landing .site-nav .menu
    display: block
    padding: 8px

  body.site-nav-on .page-landing .site-nav
    border: 1px solid var(--home-border)
    height: var(--scroll-height)
    margin-top: 8px
    visibility: unset

  .landing-hero-copy,
  .landing-hero-panel
    padding: 28px 22px

  .landing-hero h1
    font-size: 2.3rem

  .landing-hero-panel
    min-height: 270px

  .landing-section
    padding: 18px

  .landing-section-head
    align-items: flex-start
    display: grid
    gap: 8px

  .landing-section-head > p
    text-align: left

  .process-grid,
  .method-steps
    grid-template-columns: 1fr

  .landing-cta
    align-items: flex-start
    display: grid
    gap: 20px
    padding: 24px 20px

  .landing-btn.light
    justify-self: stretch
